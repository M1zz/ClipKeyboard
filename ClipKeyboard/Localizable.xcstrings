    "⌘⇧N for a new memo, ⌘⇧H for clipboard history, and more.": {
      "comment": "Mac feature: shortcuts description",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "⌘⇧N for a new memo, ⌘⇧H for clipboard history, and more."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "⌘⇧N 새 메모, ⌘⇧H 클립보드 기록 등 Mac 네이티브 단축키."
          }
        }
      }
    },
